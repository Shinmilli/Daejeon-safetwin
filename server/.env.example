# ═══════════════════════════════════════════════
# Daejeon Safe-Twin · 서버 환경변수
# 로컬: cp .env.example .env
# Render: Dashboard → Environment 에 동일 키로 등록
# ═══════════════════════════════════════════════

# Render가 자동 주입. 로컬만 4000 사용
PORT=4000

# [필수·배포] Netlify 사이트 URL (CORS)
# 예: https://safetwin-demo.netlify.app
# 여러 개면 콤마: https://a.netlify.app,https://b.netlify.app
FRONTEND_ORIGIN=http://localhost:5173

# [권장] 공공데이터포털 Encoding 인증키
# 기상청 초단기실황 + 건축물대장
# 없으면 기상/건축은 mock-fallback
DATA_GO_KR_SERVICE_KEY=

# [선택] 화학물질안전원 PRTR accessKey
# 없으면 cache sample 사용
PRTR_ACCESS_KEY=
