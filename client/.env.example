# ═══════════════════════════════════════════════
# Daejeon Safe-Twin · 프론트 환경변수 (Vite)
# 로컬: cp .env.example .env  (보통 API 비움 = proxy)
# Netlify: Site settings → Environment variables
# ═══════════════════════════════════════════════

# [필수·배포] Render 서버 주소 (끝에 / 붙이지 말 것)
# 예: https://safetwin-api.onrender.com
# 로컬 개발에서는 비워 두면 Vite가 /api → localhost:4000 프록시
VITE_API_BASE=

# [선택] 카카오맵 JS 키 (없으면 Leaflet 다크맵 사용)
VITE_KAKAO_MAP_KEY=
